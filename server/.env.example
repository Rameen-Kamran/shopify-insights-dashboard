# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# Port the Express server listens on
PORT=4000

# ---- MySQL (running natively on your machine) ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=shopify_insights
DB_USER=root
DB_PASSWORD=your_mysql_password

# ---- Shopify Admin API ----
# Your store's myshopify domain, WITHOUT https:// (e.g. my-store.myshopify.com)
SHOPIFY_STORE_URL=your-store.myshopify.com

# Admin API access token from a custom app (starts with "shpat_")
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin REST API version (use 2026-07 or later; Shopify supports each for 12 months)
SHOPIFY_API_VERSION=2026-07

# Secret used to verify incoming webhook signatures (from the webhook config)
SHOPIFY_WEBHOOK_SECRET=your_webhook_signing_secret

# Where the frontend runs, used for CORS
CLIENT_ORIGIN=http://localhost:5173
